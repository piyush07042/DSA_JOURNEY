class Solution {
    public int majorityElement(int[] nums) {
        int count= 0;
        int element = 0;
        int n = nums.length;
        for(int num:nums){
            if (count == 0){
            element = num;
            }
        if (num == element){
            count++;
        }else{
            count--;
        }
        }
        return element;
    }
}

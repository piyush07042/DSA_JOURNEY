
class Solution {
    public int longestConsecutive(int[] nums) {
        int n = nums.length;
        if (n == 0) return 0;

        int longest = 1;

        HashSet<Integer> set = new HashSet<>();

        // Step 1: Insert all elements into set
        for (int i = 0; i < n; i++) {
            set.add(nums[i]);
        }

        // Step 2: Traverse set
        for (int it : set) {
            
            // Check if it's starting element
            if (!set.contains(it - 1)) {
                int cnt = 1;
                int x = it;

                // Count consecutive sequence
                while (set.contains(x + 1)) {
                    x = x + 1;
                    cnt++;
                }

                longest = Math.max(longest, cnt);
            }
        }

        return longest;
    }
}
